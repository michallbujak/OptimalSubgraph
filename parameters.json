{
  "num_epochs": 100,
  "random_graph": {
    "no_nodes": 16,
    "edge_prob": 0.3,
    "connected": 1
  },
  "model_args": {
    "mp_units": [64,64,48],
    "mp_activation": "ReLU",
    "mlp_units": [32, 16],
