{
  "input": {
    "exact_data": true,
    "adjacency_matrix_path": "data/adj_poland.csv",
    "distances_matrix_path": "data/dist_poland.csv",
    "flow_matrix_path": "data/flow_poland.csv"
  },
  "random_graph": {
    "no_nodes": 16,
    "edge_prob": 0.3,
    "connected": true
  },
  "model_args": {
    "mp_units": [64,64,48],
    "mp_activation": "ReLU",
    "mlp_units": [32, 16],
    "mlp_activation": "ReLU",
    "final_activation": "gumbel_softmax",
    "final_activation_parameters": {
      "tau": 1
    },
    "prior_logit_shift": 3,
    "force_initial_value": false,
    "initial_value": 0
  },
  "loss_args": {
    "delta": 1e-4,
    "gamma": 1e-1,
    "utility_scale": -1e-2,
    "priority_rail": 0.5,
    "utility_gain_multiplier": -1e-3,
    "alpha_elu": 1,
    "entropy_thresholds": [1e2, 3e2, 5e2, 8e2],
    "entropy_levels": [1e0, 1e0, 1e0, 1e1, 1e1],
    "mask_thresholds": [1e2, 3e2, 5e2, 8e2],
    "mask_levels": [1, 1e1, 1e2, 1e3, 1e4],
    "lower_cost_training_power": 1,
    "lower_cost_training_period": 800
  },
  "optimizer_args": {
    "lr": 1e-3,
    "weight_decay": 1e-5
  },
  "visualization": {
    "show_training_progress": true,
    "show_training_output": true,
    "save_training_output": true,
    "label_coordinates_path": "data/coord_poland.csv",
    "figure_size": [10, 10],
    "dpi": 300
  },
  "num_epochs": 1000,
  "seed": 123
}
